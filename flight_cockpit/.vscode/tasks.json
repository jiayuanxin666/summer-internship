{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build PFD",
            "type": "shell",
            "command": "D:/MSYS2/mingw64/bin/gcc.exe",
            "args": [
                "-DSDL_MAIN_HANDLED",
                "-g",

                "src/PFD/pfd_main.c",
                "src/PFD/pfd_ui.c",
                "src/PFD/pfd_data.c",
                "src/PFD/pfd_instruments.c",

                "-o",
                "build/PFD.exe",

                "-I",
                "D:/MSYS2/mingw64/include",

                "-L",
                "D:/MSYS2/mingw64/lib",

                "-lSDL2_gfx",
                "-lSDL2_ttf",
                "-lSDL2_image",
                "-lSDL2",
                "-lws2_32",
                "-lm"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run PFD",
            "type": "shell",
            "command": "build/PFD.exe",
            "dependsOn": "build PFD",
            "group": "test"
        }
    ]
}
